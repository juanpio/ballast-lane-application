@model BLA.Ordering.Application.Auth.Dtos.RegisterUserRequest

@section Meta {
    <title>Create Account - Ballast Lane</title>
    <meta name="description" content="Create your Ballast Lane account to start managing your orders." />
    <meta property="og:title" content="Create Account - Ballast Lane" />
    <meta property="og:description" content="Create your Ballast Lane account to start managing your orders." />
    <meta property="og:type" content="website" />
    <link rel="canonical" href="/account/create" />
}

<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-lg shadow">

        <h1 class="text-2xl font-bold text-gray-900">Create Account</h1>

        @Html.ValidationSummary(true, null, new { @class = "bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700", role = "alert" })

        <form asp-action="Register" asp-controller="Account" method="post" novalidate id="register-form" class="space-y-4">

            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700">
                    Email Address <span aria-hidden="true" class="text-red-500">*</span>
                </label>
                <input asp-for="Email"
                       type="email"
                       autocomplete="email"
                       aria-required="true"
                       aria-describedby="Email-error"
                       placeholder="you@example.com"
                       class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" />
                <span asp-validation-for="Email"
                      id="Email-error"
                      role="alert"
                      class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-medium text-gray-700">
                    Password <span aria-hidden="true" class="text-red-500">*</span>
                </label>
                <input asp-for="Password"
                       type="password"
                       autocomplete="new-password"
                       aria-required="true"
                       aria-describedby="password-hint Password-error"
                       class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" />
                <p id="password-hint" class="mt-1 text-xs text-gray-500">
                    At least 8 characters with uppercase, lowercase, a number, and a special character.
                </p>
                <span asp-validation-for="Password"
                      id="Password-error"
                      role="alert"
                      class="mt-1 block text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700">
                    Confirm Password <span aria-hidden="true" class="text-red-500">*</span>
                </label>
                <input asp-for="ConfirmPassword"
                       type="password"
                       autocomplete="new-password"
                       aria-required="true"
                       aria-describedby="ConfirmPassword-error"
                       class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm" />
                <span asp-validation-for="ConfirmPassword"
                      id="ConfirmPassword-error"
                      role="alert"
                      class="mt-1 block text-sm text-red-600"></span>
            </div>

            <button type="submit"
                    id="submit-btn"
                    class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed">
                Create Account
            </button>

            <p class="text-center text-sm text-gray-600">
                Already have an account?
                <a href="/account/login" class="font-medium text-indigo-600 hover:text-indigo-500">Log in</a>
            </p>

        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/register-validation.js"></script>
}
