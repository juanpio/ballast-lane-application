@section Meta {
    <title>Account Created - Ballast Lane</title>
    <meta name="robots" content="noindex, nofollow" />
}

<div class="min-h-screen flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full text-center bg-white p-8 rounded-lg shadow space-y-4">

        <svg class="mx-auto h-12 w-12 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"
             aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>

        <h1 class="text-2xl font-bold text-gray-900">Account Created!</h1>

        <p class="text-gray-600">Your account has been created successfully.</p>
        <p class="text-sm text-gray-500" id="redirect-message">Redirecting to login in <span id="countdown">3</span> seconds&hellip;</p>

        <a href="/account/login"
           class="inline-block mt-2 font-medium text-indigo-600 hover:text-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded">
            Go to Login
        </a>
    </div>
</div>

<script>
    (function () {
        var seconds = 3;
        var countdown = document.getElementById('countdown');
        var interval = setInterval(function () {
            seconds -= 1;
            if (countdown) countdown.textContent = seconds;
            if (seconds <= 0) {
                clearInterval(interval);
                window.location.href = '/account/login';
            }
        }, 1000);
    })();
</script>
