<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="application-name" content="Ballast Lane Application" />
    <meta property="og:site_name" content="Ballast Lane Application" />
    @RenderSection("Meta", required: false)
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-900">
    <a class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:rounded focus:shadow"
       href="#main-content">
        Skip to main content
    </a>
    <main id="main-content">
        @RenderBody()
    </main>
    @RenderSection("Scripts", required: false)
</body>
</html>
