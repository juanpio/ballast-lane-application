{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ],
    "Properties": {
      "Application": "BLA.Ordering"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{MachineName}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=bla_ordering;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "BLA.Ordering",
    "Audience": "BLA.Ordering.Client",
    "Key": "BLA_LOCAL_DEV_SUPER_SECRET_KEY_CHANGE_ME_1234567890",
    "AccessTokenMinutes": 60
  },
  "AllowedHosts": "*"
}

